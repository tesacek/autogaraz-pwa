{
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR\" run build"
    ],
    "runtime": "nodejs18"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/cars",
        "function": "cars"
      },
      {
        "source": "/api/carImage",
        "function": "carImage"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}